{
  "name": "guess-number-app",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "prestart": "node scripts/generate-env.js",
    "prebuild": "node scripts/generate-env.js",
    "start": "ng serve --proxy-config proxy.conf.json",
    "start:server": "env-cmd -f ../env/.dev.env npx nest start --watch",
    "start:dev": "concurrently \"npm run start\" \"npm run start:server\"",
    "build": "ng build",
    "build:server": "npx nest build",
    "build:all": "npm run build && npm run build:server",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^19.2.20",
    "@angular/common": "^19.2.20",
    "@angular/compiler": "^19.2.20",
    "@angular/core": "^19.2.20",
    "@angular/fire": "^19.2.0",
    "@angular/forms": "^19.2.20",
    "@angular/platform-browser": "^19.2.20",
    "@angular/platform-browser-dynamic": "^19.2.20",
    "@angular/router": "^19.2.20",
    "@capacitor/android": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/ios": "^8.3.0",
    "@nestjs/common": "^11.1.17",
    "@nestjs/core": "^11.1.17",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/platform-socket.io": "^11.1.17",
    "@nestjs/serve-static": "^5.0.4",
    "@nestjs/websockets": "^11.1.17",
    "dotenv": "^17.3.1",
    "firebase": "^12.11.0",
    "google-auth-library": "^10.6.2",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "jwt-decode": "^4.0.0",
    "nanoid": "^3.3.11",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "~7.8.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.1"
  },
  "overrides": {
    "htmlparser2": {
      "entities": "^6.0.0"
    }
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.2.23",
    "@angular/cli": "^19.2.23",
    "@angular/compiler-cli": "^19.2.20",
    "@capacitor/cli": "^8.3.0",
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^11.0.9",
    "@types/express": "^5.0.6",
    "@types/jasmine": "~5.1.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/passport-jwt": "^4.0.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "env-cmd": "^10.1.0",
    "jasmine-core": "~5.2.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "tsconfig-paths": "^4.2.0",
    "typescript": "~5.5.2"
  }
